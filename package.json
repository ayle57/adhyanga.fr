{
	"name": "adhyanga.fr",
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "node_modules/.bin/vite dev",
		"build": "node_modules/.bin/vite build",
		"preview": "node_modules/.bin/vite preview",
		"check": "node_modules/.bin/svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "node_modules/.bin/svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"format": "node_modules/.bin/prettier --write .",
		"lint": "node_modules/.bin/prettier --check . && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.4",
		"@sveltejs/adapter-auto": "^3.3.1",
		"@sveltejs/kit": "^2.15.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.14.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.2",
		"sass": "^1.83.0",
		"svelte": "^5.16.0",
		"svelte-check": "^4.1.1",
		"typescript": "^5.7.2",
		"vite": "^6.0.5"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.8",
		"path": "^0.12.7"
	}
